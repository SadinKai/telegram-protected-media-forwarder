# Telegram API credentials (required)
# Get them from https://my.telegram.org
API_ID=YOUR_API_ID
API_HASH=YOUR_API_HASH

# Optional String Session for running headless on Heroku/Docker
# Generate one using 'python main.py test-connection' or 'python main.py setup'
STRING_SESSION=

# Global Configurations (Overridable in config.ini General section)
# DOWNLOAD_DIR=downloads
# LOG_LEVEL=INFO
# KEEP_DOWNLOADS=false
# MAX_RETRIES=3
# UPLOAD_DELAY=3.0
# FLOOD_WAIT_LIMIT=300
